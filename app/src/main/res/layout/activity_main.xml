<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_calculator"
    android:weightSum="10">

    <!-- Top Display Area (takes up 3.5/10 of the screen height) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="3.5"
        android:orientation="vertical"
        android:gravity="bottom|end"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvExpression"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/text_secondary"
            android:textSize="24sp"
            android:fontFamily="sans-serif-light"
            android:maxLines="3"
            android:ellipsize="start"
            android:layout_gravity="end"
            android:gravity="end" />

        <TextView
            android:id="@+id/tvResult"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="@color/text_white"
            android:textSize="56sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif"
            android:layout_gravity="end"
            android:gravity="end"
            android:layout_marginTop="8dp" />
    </LinearLayout>

    <!-- Bottom Buttons Area (takes up 6.5/10 of the screen height) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="6.5"
        android:orientation="vertical"
        android:padding="12dp"
        android:gravity="bottom">

        <!-- Row 1: AC, DEL, %, / -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAC"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="AC"
                android:textSize="20sp"
                android:textColor="@color/text_black"
                app:backgroundTint="@color/btn_function"
                app:rippleColor="@color/btn_function_pressed"
                app:cornerRadius="24dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDEL"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="DEL"
                android:textSize="20sp"
                android:textColor="@color/text_black"
                app:backgroundTint="@color/btn_function"
                app:rippleColor="@color/btn_function_pressed"
                app:cornerRadius="24dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPercent"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="%"
                android:textSize="22sp"
                android:textColor="@color/text_black"
                app:backgroundTint="@color/btn_function"
                app:rippleColor="@color/btn_function_pressed"
                app:cornerRadius="24dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDivide"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="÷"
                android:textSize="26sp"
                android:textColor="@color/text_white"
                app:backgroundTint="@color/btn_operator"
                app:rippleColor="@color/btn_operator_pressed"
                app:cornerRadius="24dp" />
        </LinearLayout>

        <!-- Row 2: 7, 8, 9, * -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn7"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="7"
                android:textSize="24sp"
                android:textColor="@color/text_white"
                app:backgroundTint="@color/btn_number"
                app:rippleColor="@color/btn_number_pressed"
                app:cornerRadius="24dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn8"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="8"
                android:textSize="24sp"
                android:textColor="@color/text_white"
                app:backgroundTint="@color/btn_number"
                app:rippleColor="@color/btn_number_pressed"
                app:cornerRadius="24dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn9"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="9"
                android:textSize="24sp"
                android:textColor="@color/text_white"
                app:backgroundTint="@color/btn_number"
                app:rippleColor="@color/btn_number_pressed"
                app:cornerRadius="24dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMultiply"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="×"
                android:textSize="26sp"
                android:textColor="@color/text_white"
                app:backgroundTint="@color/btn_operator"
                app:rippleColor="@color/btn_operator_pressed"
                app:cornerRadius="24dp" />
        </LinearLayout>

        <!-- Row 3: 4, 5, 6, - -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn4"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="4"
                android:textSize="24sp"
                android:textColor="@color/text_white"
                app:backgroundTint="@color/btn_number"
                app:rippleColor="@color/btn_number_pressed"
                app:cornerRadius="24dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn5"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="5"
                android:textSize="24sp"
                android:textColor="@color/text_white"
                app:backgroundTint="@color/btn_number"
                app:rippleColor="@color/btn_number_pressed"
                app:cornerRadius="24dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn6"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="6"
                android:textSize="24sp"
                android:textColor="@color/text_white"
                app:backgroundTint="@color/btn_number"
                app:rippleColor="@color/btn_number_pressed"
                app:cornerRadius="24dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSubtract"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="-"
                android:textSize="28sp"
                android:textColor="@color/text_white"
                app:backgroundTint="@color/btn_operator"
                app:rippleColor="@color/btn_operator_pressed"
                app:cornerRadius="24dp" />
        </LinearLayout>

        <!-- Row 4: 1, 2, 3, + -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn1"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="1"
                android:textSize="24sp"
                android:textColor="@color/text_white"
                app:backgroundTint="@color/btn_number"
                app:rippleColor="@color/btn_number_pressed"
                app:cornerRadius="24dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn2"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="2"
                android:textSize="24sp"
                android:textColor="@color/text_white"
                app:backgroundTint="@color/btn_number"
                app:rippleColor="@color/btn_number_pressed"
                app:cornerRadius="24dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn3"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="3"
                android:textSize="24sp"
                android:textColor="@color/text_white"
                app:backgroundTint="@color/btn_number"
                app:rippleColor="@color/btn_number_pressed"
                app:cornerRadius="24dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPlus"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="+"
                android:textSize="26sp"
                android:textColor="@color/text_white"
                app:backgroundTint="@color/btn_operator"
                app:rippleColor="@color/btn_operator_pressed"
                app:cornerRadius="24dp" />
        </LinearLayout>

        <!-- Row 5: +/-, 0, ., = -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnToggleSign"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="±"
                android:textSize="24sp"
                android:textColor="@color/text_white"
                app:backgroundTint="@color/btn_number"
                app:rippleColor="@color/btn_number_pressed"
                app:cornerRadius="24dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn0"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="0"
                android:textSize="24sp"
                android:textColor="@color/text_white"
                app:backgroundTint="@color/btn_number"
                app:rippleColor="@color/btn_number_pressed"
                app:cornerRadius="24dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDot"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="."
                android:textSize="24sp"
                android:textColor="@color/text_white"
                app:backgroundTint="@color/btn_number"
                app:rippleColor="@color/btn_number_pressed"
                app:cornerRadius="24dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEquals"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="="
                android:textSize="26sp"
                android:textColor="@color/text_white"
                app:backgroundTint="@color/btn_operator"
                app:rippleColor="@color/btn_operator_pressed"
                app:cornerRadius="24dp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>

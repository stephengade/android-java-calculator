<?xml version="1.0" encoding="utf-8"?>
<LinearLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    
    xmlns:app="http://schemas.android.com/apk/res-auto"
    
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:weightSum="10"
    tools:ignore="NestedWeights,VisualLintButtonSize,TouchTargetSize,Contrast,DuplicateSpeakableText">
    <!-- Top Display Area (takes up 3.0/10 of the screen height) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="3.0"
        android:orientation="vertical"
        android:gravity="bottom|end"
        android:padding="24dp">
        <TextView
            android:id="@+id/tvExpression"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/text_secondary"
            android:textSize="24sp"
            android:fontFamily="sans-serif-light"
            android:maxLines="3"
            android:ellipsize="start"
            android:layout_gravity="end"
            android:gravity="end" />
        <TextView
            android:id="@+id/tvResult"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/default_result"
            android:textColor="@color/text_white"
            android:textSize="36sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif"
            android:layout_gravity="end"
            android:gravity="end"
            android:layout_marginTop="8dp" />
    </LinearLayout>
    <!-- Bottom Buttons Area (takes up 7.0/10 of the screen height) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="7.0"
        android:orientation="vertical"
        android:padding="12dp"
        android:gravity="bottom">
        <!-- Row 0 (Scientific): sin, cos, tan, tan-1, x! -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSin"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:textAllCaps="false"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="@string/btn_sin"
                android:contentDescription="@string/desc_sin"
                android:textSize="12sp"
                android:textColor="@color/text_white"
                app:backgroundTint="@color/btn_number"
                app:rippleColor="@color/btn_number_pressed"
                app:cornerRadius="24dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCos"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:textAllCaps="false"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="@string/btn_cos"
                android:contentDescription="@string/desc_cos"
                android:textSize="12sp"
                android:textColor="@color/text_white"
                app:backgroundTint="@color/btn_number"
                app:rippleColor="@color/btn_number_pressed"
                app:cornerRadius="24dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTan"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:textAllCaps="false"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="@string/btn_tan"
                android:contentDescription="@string/desc_tan"
                android:textSize="12sp"
                android:textColor="@color/text_white"
                app:backgroundTint="@color/btn_number"
                app:rippleColor="@color/btn_number_pressed"
                app:cornerRadius="24dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnFactorial"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="@string/btn_factorial"
                android:contentDescription="@string/desc_factorial"
                android:textSize="12sp"
                android:textColor="@color/text_white"
                app:backgroundTint="@color/btn_number"
                app:rippleColor="@color/btn_number_pressed"
                app:cornerRadius="24dp" />
        </LinearLayout>

<!--        ROW 0: scientific evals-->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp"
            >

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAtan"
                android:textAllCaps="false"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="@string/btn_atan"
                android:contentDescription="@string/desc_atan"
                android:textSize="20sp"
                android:textColor="@color/text_black"
                app:backgroundTint="@color/btn_function"
                app:rippleColor="@color/btn_number_pressed"
                app:cornerRadius="24dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAcos"
                style="@style/Widget.MaterialComponents.Button"
                android:textAllCaps="false"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="@string/btn_acos"
                android:contentDescription="@string/desc_acos"
                android:textSize="20sp"
                android:textColor="@color/text_black"
                app:backgroundTint="@color/btn_function"
                app:rippleColor="@color/btn_function_pressed"
                app:cornerRadius="24dp" />


            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAsin"
                style="@style/Widget.MaterialComponents.Button"
                android:textAllCaps="false"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="@string/btn_asin"
                android:contentDescription="@string/desc_asin"
                android:textSize="20sp"
                android:textColor="@color/text_black"
                app:backgroundTint="@color/btn_function"
                app:rippleColor="@color/btn_function_pressed"
                app:cornerRadius="24dp" />


        </LinearLayout>


        <!-- Row 1: AC, DEL, %, / -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAC"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="@string/btn_ac"
                android:contentDescription="@string/desc_ac"
                android:textSize="20sp"
                android:textColor="@color/text_black"
                app:backgroundTint="@color/btn_function"
                app:rippleColor="@color/btn_function_pressed"
                app:cornerRadius="24dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDEL"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="@string/btn_del"
                android:contentDescription="@string/desc_del"
                android:textSize="20sp"
                android:textColor="@color/text_black"
                app:backgroundTint="@color/btn_function"
                app:rippleColor="@color/btn_function_pressed"
                app:cornerRadius="24dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPercent"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="@string/btn_percent"
                android:contentDescription="@string/desc_percent"
                android:textSize="22sp"
                android:textColor="@color/text_black"
                app:backgroundTint="@color/btn_function"
                app:rippleColor="@color/btn_function_pressed"
                app:cornerRadius="24dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDivide"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="@string/btn_divide"
                android:contentDescription="@string/desc_divide"
                android:textSize="26sp"
                android:textColor="@color/text_white"
                app:backgroundTint="@color/btn_operator"
                app:rippleColor="@color/btn_operator_pressed"
                app:cornerRadius="24dp" />
        </LinearLayout>
        <!-- Row 2: 7, 8, 9, * -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn7"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="@string/btn_7"
                android:textSize="24sp"
                android:textColor="@color/text_white"
                app:backgroundTint="@color/btn_number"
                app:rippleColor="@color/btn_number_pressed"
                app:cornerRadius="24dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn8"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="@string/btn_8"
                android:textSize="24sp"
                android:textColor="@color/text_white"
                app:backgroundTint="@color/btn_number"
                app:rippleColor="@color/btn_number_pressed"
                app:cornerRadius="24dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn9"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="@string/btn_9"
                android:textSize="24sp"
                android:textColor="@color/text_white"
                app:backgroundTint="@color/btn_number"
                app:rippleColor="@color/btn_number_pressed"
                app:cornerRadius="24dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMultiply"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="@string/btn_multiply"
                android:contentDescription="@string/desc_multiply"
                android:textSize="26sp"
                android:textColor="@color/text_white"
                app:backgroundTint="@color/btn_operator"
                app:rippleColor="@color/btn_operator_pressed"
                app:cornerRadius="24dp" />
        </LinearLayout>
        <!-- Row 3: 4, 5, 6, - -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn4"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="@string/btn_4"
                android:textSize="24sp"
                android:textColor="@color/text_white"
                app:backgroundTint="@color/btn_number"
                app:rippleColor="@color/btn_number_pressed"
                app:cornerRadius="24dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn5"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="@string/btn_5"
                android:textSize="24sp"
                android:textColor="@color/text_white"
                app:backgroundTint="@color/btn_number"
                app:rippleColor="@color/btn_number_pressed"
                app:cornerRadius="24dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn6"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="@string/btn_6"
                android:textSize="24sp"
                android:textColor="@color/text_white"
                app:backgroundTint="@color/btn_number"
                app:rippleColor="@color/btn_number_pressed"
                app:cornerRadius="24dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSubtract"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="@string/btn_subtract"
                android:contentDescription="@string/desc_subtract"
                android:textSize="28sp"
                android:textColor="@color/text_white"
                app:backgroundTint="@color/btn_operator"
                app:rippleColor="@color/btn_operator_pressed"
                app:cornerRadius="24dp" />
        </LinearLayout>
        <!-- Row 4: 1, 2, 3, + -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn1"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="@string/btn_1"
                android:textSize="24sp"
                android:textColor="@color/text_white"
                app:backgroundTint="@color/btn_number"
                app:rippleColor="@color/btn_number_pressed"
                app:cornerRadius="24dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn2"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="@string/btn_2"
                android:textSize="24sp"
                android:textColor="@color/text_white"
                app:backgroundTint="@color/btn_number"
                app:rippleColor="@color/btn_number_pressed"
                app:cornerRadius="24dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn3"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="@string/btn_3"
                android:textSize="24sp"
                android:textColor="@color/text_white"
                app:backgroundTint="@color/btn_number"
                app:rippleColor="@color/btn_number_pressed"
                app:cornerRadius="24dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPlus"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="@string/btn_plus"
                android:contentDescription="@string/desc_plus"
                android:textSize="26sp"
                android:textColor="@color/text_white"
                app:backgroundTint="@color/btn_operator"
                app:rippleColor="@color/btn_operator_pressed"
                app:cornerRadius="24dp" />
        </LinearLayout>
        <!-- Row 5: +/-, 0, ., = -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnToggleSign"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="@string/btn_toggle_sign"
                android:contentDescription="@string/desc_toggle_sign"
                android:textSize="24sp"
                android:textColor="@color/text_white"
                app:backgroundTint="@color/btn_number"
                app:rippleColor="@color/btn_number_pressed"
                app:cornerRadius="24dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn0"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="@string/btn_0"
                android:textSize="24sp"
                android:textColor="@color/text_white"
                app:backgroundTint="@color/btn_number"
                app:rippleColor="@color/btn_number_pressed"
                app:cornerRadius="24dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDot"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="@string/btn_dot"
                android:textSize="24sp"
                android:textColor="@color/text_white"
                app:backgroundTint="@color/btn_number"
                app:rippleColor="@color/btn_number_pressed"
                app:cornerRadius="24dp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEquals"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_margin="4dp"
                android:text="@string/btn_equals"
                android:contentDescription="@string/desc_equals"
                android:textSize="26sp"
                android:textColor="@color/text_white"
                app:backgroundTint="@color/btn_operator"
                app:rippleColor="@color/btn_operator_pressed"
                app:cornerRadius="24dp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
